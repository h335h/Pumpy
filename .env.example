# Telegram API (получить на my.telegram.org)
TG_API_ID=123456
TG_API_HASH=your_api_hash_here

# VK Group Token (с правами на сообщения)
VK_GROUP_TOKEN=vk1.a.xxxxx

# ID получателей (через запятую)
VK_RECIPIENTS=123456789,987654321

# Порог семантической фильтрации
INTEREST_THRESHOLD=0.6

# Количество статей в дайджесте
TOP_N=10

# Параметры свежести
FRESHNESS_ALPHA=0.2
FRESHNESS_BETA=30
